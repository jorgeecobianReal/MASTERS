# ─────────────────────────────────────────────────────────────
# MasterMatch AI · Backend · Variables de entorno (plantilla)
# Copia este archivo a `.env` y ajusta los valores.
# ─────────────────────────────────────────────────────────────

# Entorno: development | test | production
NODE_ENV=development

# Puerto del servidor HTTP
PORT=4000

# Orígenes permitidos por CORS (separados por comas). Usa * para permitir todos.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ── Base de datos PostgreSQL ──────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# Si usas el docker-compose incluido, este valor funciona tal cual:
DATABASE_URL=postgresql://mastermatch:mastermatch@localhost:5432/mastermatch?schema=public

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── Logging ───────────────────────────────────────────────────
# Niveles: debug | info | warn | error
LOG_LEVEL=info
# Formato de logs: pretty (legible) | json (producción)
LOG_FORMAT=pretty

# ── Capa de IA (OPCIONAL) ─────────────────────────────────────
# Si no defines AI_API_KEY, el sistema funciona solo con scoring clásico.
# Compatible con OpenAI y cualquier endpoint estilo OpenAI (chat/completions).
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
AI_TIMEOUT_MS=15000
# Activa/desactiva explícitamente la IA aunque haya API key (true/false)
AI_ENABLED=true
